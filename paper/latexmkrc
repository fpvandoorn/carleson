# 5 tells latexmk to use xelatex to generate the PDF
$pdf_mode = 5;

# Define the xelatex command with the required placeholders
$xelatex = 'xelatex -shell-escape -interaction=nonstopmode -file-line-error -synctex=1 %O %S';

# Default file to compile if no file is specified in the terminal
@default_files = ('main.tex');

$bibtex = 'biber';