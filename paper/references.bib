@Article{FlyspeckComplete,
  author     = {Hales, Thomas and Adams, Mark and Bauer, Gertrud and Dang, Tat Dat and Harrison, John and Le Truong Hoang and Kaliszyk, Cezary and Magron, Victor and McLaughlin, Sean and Nguyen, Tat Thang and Nguyen, Quang Truong and Nipkow, Tobias and Obua, Steven and Pleso, Joseph and Rute, Jason and Solovyev, Alexey and Ta, Thi Hoai An and Tran, Nam Trung and Trieu, Thi Diep and Urban, Josef and Vu, Ky and Zumkeller, Roland},
  title      = {A formal proof of the {K}epler conjecture},
  journal    = {Forum Math. Pi},
  year       = {2017},
  volume     = {5},
  pages      = {e2, 29},
  issn       = {2050-5086},
  abstract   = {This article describes a formal proof of the Kepler conjecture on dense sphere packings in a combination of the HOL Light and Isabelle proof assistants. This paper constitutes the official published account of the now completed Flyspeck project.},
  doi        = {10.1017/fmp.2017.1},
  fjournal   = {Forum of Mathematics. Pi},
  mrclass    = {52C17 (05B40)},
  mrnumber   = {3659768},
  mrreviewer = {Martin\ Henk},
  review     = {The Kepler conjecture claims that the face-centered cubic packing is the densest packing of congruent balls in R3. Ferguson and Hales announced its proof in 1998, but due to the complexity of their computer proof, it was published more than 7 years later [T. C. Hales, Ann. of Math. (2) 162 (2005), no. 3, 1065–1185; MR2179728; T. C. Hales and S. P. Ferguson, The Kepler conjecture, Springer, New York, 2011; MR3075372], but without complete certification from the referees.
  The purpose of the Flyspeck project, launched by Hales in 2003 and successfully completed in 2014, was to produce a formal proof of the Kepler conjecture. The paper under review describes on a meta level, i.e., the main steps, how the proof of the Kepler conjecture has been formalised via the proof assistants HOL Light and Isabelle. The details of the proof which is formalised are given in Hales' book Dense sphere packings [London Math. Soc. Lecture Note Ser., 400, Cambridge Univ. Press, Cambridge, 2012; MR3012355] and for the code of the formalisation and documentation, see github.com/flyspeck/flyspeck.},
  url        = {https://www.cambridge.org/core/journals/forum-of-mathematics-pi/article/formal-proof-of-the-kepler-conjecture/78FBD5E1A3D1BCCB8E0D5B0C463C9FBC},
}

