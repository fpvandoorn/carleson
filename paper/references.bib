@Article{ImmlerLorentzSolver,
  author     = {Immler, Fabian},
  title      = {A Verified ODE Solver and the Lorenz Attractor},
  journal    = {J. Autom. Reason.},
  year       = {2018},
  volume     = {61},
  number     = {1–4},
  pages      = {73–111},
  month      = jun,
  issn       = {0168-7433},
  abstract   = {A rigorous numerical algorithm, formally verified with Isabelle/HOL, is used to certify the computations that Tucker used to prove chaos for the Lorenz attractor. The verification is based on a formalization of a diverse variety of mathematics and algorithms. Formalized mathematics include ordinary differential equations and Poincar\'{e} maps. Algorithms include low level approximation schemes based on Runge---Kutta methods and affine arithmetic. On a high level, reachability analysis is guided by static hybridization and adaptive step-size control and splitting. The algorithms are systematically refined towards an implementation that can be executed on Tucker's original input data.},
  address    = {Berlin, Heidelberg},
  doi        = {10.1007/s10817-017-9448-y},
  issue_date = {June 2018},
  keywords   = {Isabelle/HOL, Lorenz attractor, Ordinary differential equation, Poincar\'{e} map, Rigorous numerics},
  numpages   = {39},
  publisher  = {Springer-Verlag},
  url        = {https://link.springer.com/article/10.1007/s10817-017-9448-y},
}

@Unpublished{AvigadPNT,
  author       = {Jeremy Avigad and Kevin Donnelly and David Gray and Paul Raff},
  title        = {A formally verified proof of the prime number theorem},
  year         = {2005},
  abstract     = {The prime number theorem, established by Hadamard and de la Vall'ee Poussin independently in 1896, asserts that the density of primes in the positive integers is asymptotic to 1 / ln x. Whereas their proofs made serious use of the methods of complex analysis, elementary proofs were provided by Selberg and Erd"os in 1948. We describe a formally verified version of Selberg's proof, obtained using the Isabelle proof assistant.},
  howpublished = {arXiv:cs/0509025 [cs.AI]},
  url          = {https://arxiv.org/abs/cs/0509025},
}

